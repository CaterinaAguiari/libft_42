/*                                                                            */
/* ************************************************************************** */

#include "libft.h"

int	ft_toupper(int c)
{
	unsigned char	target;

	target = (unsigned char)c;
	if (target >= 97 && target <= 122)
	{
		target = (target - 32);
		return (target);
	}
	else
		return (target);
}
