/*                                                +#+#+#+#+#+   +#+           */
/*   Created: 2026/05/28 21:40:07 by caguiari          #+#    #+#             */
/*   Updated: 2026/05/28 21:46:41 by caguiari         ###   ########.fr       */
/*                                                                            */
/* ************************************************************************** */

#include "libft.h"

char	*ft_substr(char const *s, unsigned int start, size_t len)
{
	size_t	s_len;
	char	*sub_str;
	size_t	i;

	i = 0;
	if (s == NULL)
		return (NULL);
	s_len = ft_strlen(s);
	if (start >= s_len)
		return (ft_strdup(""));
	if (len > (s_len - start))
		len = (s_len - start);
	sub_str = (char *) malloc (len + 1);
	if (sub_str == NULL)
		return (NULL);
	while (i < len)
	{
		sub_str[i] = s[start + i];
		i++;
	}
	sub_str[i] = '\0';
	return (sub_str);
}

