/* ************************************************************************** */

#include "libft.h"

char	*ft_strrchr(const char *s, int c)
{
	unsigned char	target;
	int				i;

	i = ft_strlen(s);
	target = (unsigned char)c;
	while (i >= 0)
	{
		if ((unsigned char)s[i] == target)
			return ((char *)&s[i]);
		i--;
	}
	return (NULL);
}
