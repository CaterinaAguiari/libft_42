/*   Created: 2026/05/29 15:25:55 by caguiari          #+#    #+#             */
/*   Updated: 2026/05/29 15:32:58 by caguiari         ###   ########.fr       */
/*                                                                            */
/* ************************************************************************** */

#include "libft.h"

char	*ft_strmapi(char const *s, char (*f)(unsigned int, char))
{
	unsigned int	i;
	size_t			s_len;
	char			*d;

	i = 0;
	if (!s || !f)
		return (NULL);
	s_len = ft_strlen(s);
	d = (char *)malloc(s_len + 1);
	if (d == NULL)
		return (NULL);
	while (s[i])
	{
		d[i] = f(i, s[i]);
		i++;
	}
	d[i] = '\0';
	return (d);
}

