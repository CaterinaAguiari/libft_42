/* ************************************************************************** */
/*                                                                            */
/*                                                        :::      ::::::::   */
/*   ft_split.c                                         :+:      :+:    :+:   */
/*                                                    +:+ +:+         +:+     */
/*   By: caguiari <caguiari@student.42roma.it>      +#+  +:+       +#+        */
/*                                                +#+#+#+#+#+   +#+           */
/*   Created: 2026/05/28 23:55:17 by caguiari          #+#    #+#             */
/*   Updated: 2026/05/29 00:23:50 by caguiari         ###   ########.fr       */
/*                                                                            */
/* ************************************************************************** */

#include "libft.h"
#include <stdio.h>
#include <stdlib.h>

char	*ft_substr(char const *s, unsigned int start, size_t len);

static int	ft_count_words(char const *s, char c)
{
	int	i;
	int	count;

	count = 0;
	i = 0;
	while (s[i])
	{
		if (s[i] != c && (s[i + 1] == '\0' || s[i + 1] == c))
			count++;
		i++;
	}
	return (count);
}

static void	*ft_free_all(char **tab, int j)
{
	while (j > 0)
	{
		j--;
		free(tab[j]);
	}
	free(tab);
}

static char	*ft_get_word(char const *s, char c, int *i)
{
	int	start;

	while (s[*i] == c)
		(*i)++;
	if (!s[*i])
		return (NULL);
	start = *i;
	while (s[*i] && s[*i] != c)
		(*i)++;
	return (ft_substr(s, start, *i - start));
}

char	**ft_split(const char *s, char c)
{
	char	**tab;
	int		i;
	int		j;

	if (!s)
		return (NULL);
	tab = malloc(sizeof(char *) * (ft_count_words(s, c) + 1));
	if (!tab)
		return (NULL);
	i = 0;
	j = 0;
	while (s[i])
	{
		tab[j] = ft_get_word(s, c, &i);
		if (!tab[j])
		{
			if (s[i] == '\0')
				break ;
			return (ft_free_all(tab, j), NULL);
		}
		j++;
	}
	tab[j] = NULL;
	return (tab);
}

int	main(void)
{
	char	**tab;
	int		i;

	i = 0;
	tab = ft_split("ciao come stai oggi", ' ');
	if (!tab)
		return (printf("NULL\n"), 1);
	while (tab[i])
	{
		if (!tab[i])
			break ;
		printf("%s\n", tab[i]);
		free(tab[i]);
		i++;
	}
	free(tab);
}

